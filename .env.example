DATABASE_URL=file:./data/sailsimplified.sqlite
BETTER_AUTH_SECRET=replace-with-32-bytes-random-base64
BETTER_AUTH_URL=http://localhost:3200

# Optional — "Sign in with SailPoint" via OIDC.
# Leave empty to disable; the button will be hidden on the auth pages.
# To enable, register an OIDC application in your SailPoint ISC tenant
# (Admin → Global → Security Settings → API Management → New) with redirect URI:
#   <BETTER_AUTH_URL>/api/auth/oauth2/callback/sailpoint
SAILPOINT_DISCOVERY_URL=
SAILPOINT_CLIENT_ID=
SAILPOINT_CLIENT_SECRET=
