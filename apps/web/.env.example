DATABASE_URL=file:./data/simplified-identity.sqlite
BETTER_AUTH_SECRET=replace-with-32-bytes-random-base64
BETTER_AUTH_URL=http://localhost:3200

# Optional — "Sign in with SailPoint" via OAuth 2.0.
# Leave SAILPOINT_TENANT empty to disable; the button will show a friendly
# "not configured" message on click instead of triggering the OAuth flow.
#
# To enable:
# 1. Find your tenant slug: ISC Dashboard → Overview → Org Details → "Org Name".
#    Example: if your URL is https://acme-sb.identitynow.com, slug = acme-sb.
# 2. Register an API client: ISC → Administrator → API Management → New.
#    - Grant types: tick "Code d'autorisation" (Authorization Code) AND
#      "Jeton de rafraîchissement" (Refresh Token).
#    - Redirect URL: <BETTER_AUTH_URL>/api/auth/oauth2/callback/sailpoint
#    - Scopes: leave all OFF for sign-in only.
# 3. Copy the generated Client ID + Client Secret immediately — the secret
#    is only shown once.
SAILPOINT_TENANT=
SAILPOINT_CLIENT_ID=
SAILPOINT_CLIENT_SECRET=
